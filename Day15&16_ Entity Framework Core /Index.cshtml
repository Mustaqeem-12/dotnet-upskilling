@model List<InventoryApi.Models.Product>

<h2 style="text-align:center; margin-top:20px;">📦 Product Inventory</h2>

<div style="text-align:center; margin-bottom:20px;">
    <a href="/Product/Create"
       style="padding:10px 20px; background-color:green; color:white; text-decoration:none; border-radius:5px;">
        ➕ Add New Product
    </a>
</div>

<table style="width:80%; margin:auto; border-collapse:collapse; text-align:center;">
    <thead style="background-color:#007bff; color:white;">
        <tr>
            <th style="padding:10px;">Id</th>
            <th style="padding:10px;">Product Name</th>
            <th style="padding:10px;">Price</th>
            <th style="padding:10px;">Quantity</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr style="border-bottom:1px solid #ddd;">
                <td style="padding:10px;">@item.Id</td>
                <td style="padding:10px;">@item.ProductName</td>
                <td style="padding:10px;">₹@item.Price</td>
                <td style="padding:10px;">@item.Quantity</td>
            </tr>
        }
    </tbody>
</table>
