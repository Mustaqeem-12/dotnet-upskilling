@model IEnumerable<EmployeeManagement.Models.Employee>

<div class="container mt-4">
    <h2 class="text-center mb-4">Employee List</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">+ Add Employee</a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-striped table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>EmpId</th>
                <th>Name</th>
                <th>Email</th>
                <th>Salary</th>
                <th>Department</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmpId</td>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Salary</td>
                    <td>@item.Department?.Name</td>
                    <td>@item.CreatedAt</td>
                    <td>
                        <a asp-action="Edit" asp-route-empId="@item.EmpId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-empId="@item.EmpId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-empId="@item.EmpId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
